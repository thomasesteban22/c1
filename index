</div><!-- /main -->

<script>
/* ─── STARS ─── */
(function(){
  const c = document.getElementById('stars');
  for (let i = 0; i < 140; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const sz = Math.random() * 2.6 + 0.4;
    s.style.cssText = `
      width:${sz}px; height:${sz}px;
      left:${Math.random()*100}%; top:${Math.random()*100}%;
      --d:${2+Math.random()*5}s;
      --delay:-${Math.random()*7}s;
      --op:${0.25+Math.random()*0.75};
    `;
    c.appendChild(s);
  }
})();

/* ─── FLOATING HEARTS ─── */
function spawnHearts(n) {
  const syms = ['💜','🌸','✨','💫','🌙','🌺'];
  for (let i = 0; i < n; i++) {
    setTimeout(() => {
      const h = document.createElement('div');
      h.className = 'heart-float';
      h.textContent = syms[Math.floor(Math.random() * syms.length)];
      h.style.cssText = `
        left:${Math.random()*96}vw; bottom:0;
        font-size:${14+Math.random()*18}px;
        animation-duration:${4+Math.random()*4}s;
      `;
      document.body.appendChild(h);
      setTimeout(() => h.remove(), 9000);
    }, i * 100);
  }
}

/* ─── ENVELOPE ─── */
document.getElementById('env-btn').addEventListener('click', function() {
  document.getElementById('envelope-scene').classList.add('hidden');
  document.getElementById('main').classList.add('visible');
  spawnHearts(14);
});

/* ─── CAROUSEL ─── */
const TOTAL = document.querySelectorAll('.carousel-slide').length;
const track = document.getElementById('track');
const bar   = document.getElementById('bar');
const dotsW = document.getElementById('dots');
let cur = 0, timer;

// build dots
for (let i = 0; i < TOTAL; i++) {
  const d = document.createElement('button');
  d.className = 'dot' + (i === 0 ? ' active' : '');
  d.setAttribute('aria-label', 'Ir a ' + (i+1));
  d.addEventListener('click', () => goTo(i));
  dotsW.appendChild(d);
}

function goTo(n) {
  cur = ((n % TOTAL) + TOTAL) % TOTAL;
  track.style.transform = `translateX(-${cur * 100}%)`;
  bar.style.width = `${((cur + 1) / TOTAL) * 100}%`;
  dotsW.querySelectorAll('.dot').forEach((d, i) =>
    d.classList.toggle('active', i === cur));
  resetTimer();
}

function resetTimer() {
  clearInterval(timer);
  timer = setInterval(() => goTo(cur + 1), 10000);
}

document.getElementById('prev').addEventListener('click', () => goTo(cur - 1));
document.getElementById('next').addEventListener('click', () => goTo(cur + 1));

// touch swipe
let tx = 0;
track.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
track.addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - tx;
  if (Math.abs(dx) > 40) goTo(cur + (dx < 0 ? 1 : -1));
});

goTo(0); // init

/* ─── REASONS ─── */
const msgEl = document.getElementById('reason-msg');
document.querySelectorAll('.reason-card').forEach(card => {
  card.addEventListener('click', function() {
    msgEl.style.opacity = '0';
    setTimeout(() => {
      msgEl.textContent = this.dataset.msg;
      msgEl.style.opacity = '1';
    }, 200);
    this.classList.remove('lit');
    void this.offsetWidth;
    this.classList.add('lit');
    spawnHearts(4);
  });
});

